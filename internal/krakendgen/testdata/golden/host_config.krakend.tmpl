{
    "endpoint": "/api/v1/normal",
    "method": "GET",
    "output_encoding": "json",
    "backend": [
        {
            "url_pattern": "/api/v1/normal",
            "encoding": "json",
            "sd": "static",
            "method": "GET",
            "host": ["{{ .vars.host_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ]
},
{
    "endpoint": "/api/v1/override",
    "method": "GET",
    "output_encoding": "json",
    "backend": [
        {
            "url_pattern": "/api/v1/override",
            "encoding": "json",
            "sd": "static",
            "method": "GET",
            "host": ["{{ .vars.host_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ]
}
