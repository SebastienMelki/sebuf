{
    "endpoint": "/api/v1/documents",
    "method": "POST",
    "output_encoding": "json",
    "concurrent_calls": 2,
    "input_headers": ["Authorization","X-API-Key","X-User"],
    "backend": [
        {
            "url_pattern": "/api/v1/documents",
            "encoding": "json",
            "sd": "static",
            "method": "POST",
            "host": ["{{ .vars.full_gateway_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ],
    "extra_config": {
        {{ template "jwt_auth_validator.tmpl" . }}
    }
},
{
    "endpoint": "/api/v1/documents/{id}",
    "method": "GET",
    "output_encoding": "json",
    "concurrent_calls": 2,
    "input_headers": ["Authorization","X-API-Key","X-Request-ID","X-User"],
    "backend": [
        {
            "url_pattern": "/api/v1/documents/{id}",
            "encoding": "json",
            "sd": "static",
            "method": "GET",
            "host": ["{{ .vars.full_gateway_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ],
    "extra_config": {
        {{ template "jwt_auth_validator.tmpl" . }}
    }
}
