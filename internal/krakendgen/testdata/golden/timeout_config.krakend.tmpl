{
    "endpoint": "/api/v1/slow",
    "method": "POST",
    "output_encoding": "json",
    "backend": [
        {
            "url_pattern": "/api/v1/slow",
            "encoding": "json",
            "sd": "static",
            "method": "POST",
            "host": ["{{ .vars.timeout_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ]
},
