{
    "endpoint": "/api/v1/combined",
    "method": "GET",
    "output_encoding": "json",
    "input_headers": ["X-API-Key","X-Correlation-ID"],
    "input_query_strings": ["limit","q"],
    "backend": [
        {
            "url_pattern": "/api/v1/combined",
            "encoding": "json",
            "sd": "static",
            "method": "GET",
            "host": ["{{ .vars.combined_forwarding_service_host }}"],
            "disable_host_sanitize": false,
            "extra_config": {
                "backend/http": {
                    "return_error_code": true
                }
            }
        }
    ]
}
